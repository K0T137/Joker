# Copy this to .env and fill in the values

# Google OAuth (from Google Cloud Console)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
# Dev: http://localhost:3000/api/auth/google/callback  (direct to backend, bypasses Vite proxy)
# Prod: https://your-railway-app.up.railway.app/api/auth/google/callback
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# Random secret for JWT signing (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=9a10dad5e60e496b3e919feef7a7e457fd5a5f42a2a7da6853de217868ffde27

# PostgreSQL connection string (from Railway: Postgres → Connect → DATABASE_URL)
DATABASE_URL=postgresql://user:password@host:port/dbname

# URL of the frontend (used for OAuth redirect after login)
# Dev: http://localhost:5173
# Prod: https://your-app.up.railway.app
FRONTEND_URL=http://localhost:5173

# Allowed CORS origin for Socket.io dev mode
CORS_ORIGIN=http://localhost:5173
